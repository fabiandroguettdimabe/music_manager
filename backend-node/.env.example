# Copia este archivo a .env y rellena los valores reales (NO subir .env al repo).

# PostgreSQL — rol y base dedicados para la app
DATABASE_URL="postgresql://realshuffle:CAMBIA_ESTA_CLAVE@localhost:5432/realshuffle?schema=public"

# Secreto para firmar los JWT de sesión de la app (genera uno largo y aleatorio)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Clave para cifrar en reposo las credenciales de proveedor (ProviderAccount.authJson)
CREDENTIALS_ENC_KEY="cambia-esto-por-32-bytes-en-base64"

# Gemini (opcional): habilita el asistente IA y el motor de IA de "Descubrir similares".
# Gratis en https://aistudio.google.com/apikey. Sin ella, Descubrir usa solo el automix
# de YouTube Music (las semillas de Spotify se resuelven a YT si no hay match nativo).
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash"
