# Copia a refresh.env (chmod 600) y rellena. Lo lee el service de systemd.
# El mismo JWT_SECRET que usa el backend Noir — con él el refresco firma su token corto.
JWT_SECRET=pega-aqui-el-mismo-secreto-del-backend
BASE_URL=http://127.0.0.1:8000
# Opcional: fuerza Chrome real en vez del Chromium de Playwright.
# NOIR_CHROME_CHANNEL=chrome
