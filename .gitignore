# ─── Dependencias ───
node_modules/
.venv/
__pycache__/
*.pyc

# ─── Builds ───
dist/
build/
# APK/artefactos de la app Android (se generan con Gradle; no se versionan)
*.apk
*.aab

# ─── Entorno y secretos — NUNCA subir ───
.env
.env.local
.env.*.local
# (se conservan .env.example y .env.deploy.example como plantillas)

# ─── Volcados de BD (contienen cookies/tokens cifrados) — NUNCA subir ───
*.dump
realshuffle.dump

# ─── Credenciales / tokens (migradas a la BD; nunca subir) ───
oauth.json
oauth_no_client.json
spotify_token.json
yt_oauth.json

# ─── Logs ───
*.log

# ─── Postgres local dedicado (clúster de desarrollo en :5433) ───
.pgdata/

# ─── Prisma ───
# (las migraciones SÍ se versionan; solo se ignora el cliente generado si existiera)

# ─── IDE / OS ───
.idea/
.vscode/
.DS_Store
Thumbs.db

# Caché de audio offline (runtime, no versionar)
backend-node/storage/

# Basura de trabajo
# Backups DB
backup_*.sql
backup_*.dump
*.dump
# Comprimidos
*.rar
*.7z
basura_*.zip
# Docs de auditoría (en cualquier nivel)
AUDITORIA*.md
AUDITORIA*.pdf
ANALISIS_*
MEJORAS_*
EXPLICACION_*
COMPARACION_*
CONSOLIDACION_*
OBSERVACIONES_*
GUIA_PRUEBA_*
# Archivos por error
--dev=*
