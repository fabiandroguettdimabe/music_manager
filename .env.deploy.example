# Copia este archivo a .env en el VPS y rellena los valores.
#   cp .env.deploy.example .env

# ── Postgres (contenedor) ──
POSTGRES_PASSWORD=cambia-esto-por-una-clave-fuerte

# ── Secretos de la app ──
# JWT_SECRET: cualquier cadena larga aleatoria (los tokens ya emitidos dejan de valer si la cambias).
JWT_SECRET=genera-una-cadena-larga-aleatoria
# CREDENTIALS_ENC_KEY: DEBE ser EXACTAMENTE la misma que usas en tu PC local.
# Con ella se cifran/descifran tus cookies de YouTube y tokens de Spotify. Si no coincide,
# tras migrar la BD la app no podrá leer tus credenciales y tendrías que reconectar todo.
CREDENTIALS_ENC_KEY=copia-la-de-tu-.env-local

# ── Gemini (asistente IA) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Sync (déjalo como en local) ──
SYNC_ENABLED=false
SYNC_INTERVAL_MIN=60
SYNC_MAX_PAGES=5
SYNC_PER_RUN=200

# ── Dominio (Caddy saca el HTTPS solo) ──
# Ej.: mimusica.duckdns.org  (gratis con DuckDNS) o tu propio dominio.
SITE_ADDRESS=tuapp.duckdns.org

# ── CORS: orígenes permitidos (coma-separado). En el despliegue single-origin
# (NestJS sirve el frontend) suele bastar con tu propio dominio. Si lo dejas vacío,
# la API refleja cualquier origin (cómodo en dev, NO recomendado en público).
ALLOWED_ORIGINS=https://tuapp.duckdns.org
